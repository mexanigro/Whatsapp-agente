# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: meta | twilio
WHATSAPP_PROVIDER=twilio

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Templates Twilio Content API (opcionales) ─────────────
# Si no estan configurados, las notificaciones se envian como texto libre.
# Para mensajes fuera del service window (>24h sin contacto del cliente) son obligatorios.
# Crear en Twilio Console > Messaging > Content Template Builder.
TWILIO_TEMPLATE_APPT_CONFIRMATION=
TWILIO_TEMPLATE_APPT_REMINDER=
TWILIO_TEMPLATE_APPT_REVIEW=
TWILIO_TEMPLATE_APPT_CANCELLED=
TWILIO_TEMPLATE_APPT_STAFF=
TWILIO_TEMPLATE_NEW_LEAD=
TWILIO_TEMPLATE_LEAD_FOLLOWUP=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio webhook signature validation (produccion) ──────
# URL publica del webhook para validar firmas X-Twilio-Signature.
# Si esta detras de un reverse proxy/Railway, dejar vacio y el codigo
# usa x-forwarded-proto/host para reconstruir.
WEBHOOK_BASE_URL=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
# Default si no se setea: production (fail-secure).
ENVIRONMENT=development
# SOLO desarrollo local: saltea la validacion de firma de Twilio.
# Se ignora si ENVIRONMENT=production. NUNCA activar en produccion.
TWILIO_SKIP_SIGNATURE=false

# ── Base de datos ─────────────────────────────────────────
DB_PATH=agentkit.db

# ── Negocio ───────────────────────────────────────────────
# Numero del admin (Liam) en formato internacional. Recibe escalaciones,
# comandos #pausa/#volver/#lead/#stats, etc.
ADMIN_PHONE_NUMBER=
# Nombre del negocio para incluir en plantillas (opcional)
BUSINESS_NAME=Arzac Studio
# TZ del negocio (IANA). Default Asia/Jerusalem.
BUSINESS_TIMEZONE=Asia/Jerusalem

# ── Cap de costos ─────────────────────────────────────────
# Limite diario en USD. Cuando se alcanza, se ignoran nuevos mensajes
# hasta el dia siguiente.
COSTO_DIARIO_MAXIMO=2.0

# ── Comportamiento ────────────────────────────────────────
# Si "true", fuera de horario se responde con mensaje fijo (ahorra tokens).
AUTO_REPLY_FUERA_HORARIO=true
# Si "true", deteccion de urgencia + escalacion automatica.
ESCALACION_ACTIVA=true
# Horas para programar follow-up automatico (lead no responde).
FOLLOWUP_LEAD_HORAS=24
# Maximas respuestas concurrentes (backpressure).
MAX_CONCURRENT_RESPONSES=20
# Limite de caracteres por mensaje entrante (anti payloads gigantes al LLM).
MAX_MESSAGE_LENGTH=4000
# Segundos de espera para agrupar mensajes consecutivos en una sola respuesta.
# DEBOUNCE_MENSAJES_SEGUNDOS=8

# ── Integracion con nichos-hub ────────────────────────────
# URL base de nichos-hub (donde estan los endpoints /api/appointments/*)
NICHOS_HUB_URL=
# Secret compartido para autenticar requests entre nichos-hub y agentkit.
# OBLIGATORIO en produccion — sin esto los endpoints /notify, /status, /tasks/* devuelven 503.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_API_SECRET=
# ID del cliente al que pertenece esta instancia del agente
CLIENT_ID=

# ── Voz: notas de voz (Fase 1) ────────────────────────────
# STT: OpenAI gpt-4o-mini-transcribe ($0.003/min, los 5 idiomas incl. hebreo)
OPENAI_API_KEY=
# OPENAI_STT_MODEL=gpt-4o-mini-transcribe
# TTS: ElevenLabs Flash v2.5 ($0.05/1K chars, voz humana en los 5 idiomas)
ELEVENLABS_API_KEY=
# Voice ID de ElevenLabs (la "voz del negocio"). Obligatorio para responder audios.
ELEVENLABS_VOICE_ID=
# Overrides opcionales de voz por idioma (default: ELEVENLABS_VOICE_ID para todos)
# ELEVENLABS_VOICE_ID_ES=
# ELEVENLABS_VOICE_ID_EN=
# ELEVENLABS_VOICE_ID_HE=
# ELEVENLABS_VOICE_ID_RU=
# ELEVENLABS_VOICE_ID_AR=
# Prosodia (ver VOICE-HUMANIZATION.md antes de tocar)
# stability baja = mas emotiva; similarity alta = timbre estable
# ELEVENLABS_STABILITY=0.4
# ELEVENLABS_SIMILARITY=0.8
# ELEVENLABS_STYLE=0.2
# ELEVENLABS_SPEED=1.0
# Modelo TTS de ElevenLabs (default: eleven_flash_v2_5). Ver VOICE-HUMANIZATION.md.
# ELEVENLABS_MODEL=eleven_flash_v2_5
# Formato de audio de salida (default: ogg_48000_128k_opus — nota de voz nativa en WhatsApp)
# ELEVENLABS_OUTPUT_FORMAT=ogg_48000_128k_opus
# Carpeta de audios temporales (se borran a las 24h via /tasks/limpieza)
# MEDIA_DIR=media_temp
# Horas de vida de los audios temporales antes de borrarse.
# MEDIA_TTL_HORAS=24

# ── Voz: llamadas WhatsApp + ConversationRelay (Fase 2) ───
# Requiere onboarding previo en Twilio Console > Voice > ConversationRelay
# y habilitacion de ElevenLabs en la cuenta (error 64101 si falta).
# Webhook de voz en Twilio: POST https://tu-app.up.railway.app/voice
LLAMADAS_ACTIVAS=true
# Modelo para llamadas (latencia minima). Default: Haiku.
# VOICE_CLAUDE_MODEL=claude-haiku-4-5-20251001
# VOICE_MAX_TOKENS=300
# Idioma de arranque si el cliente no tiene historial (he|es|en|ru|ar)
# VOICE_IDIOMA_DEFAULT=he
# Token del WebSocket de voz. Default: derivado de AGENT_API_SECRET.
# VOICE_WS_TOKEN=
# Modelo TTS dentro de ConversationRelay (flash_v2_5|flash_v2|turbo_v2_5|turbo_v2)
# VOICE_CR_TTS_MODEL=flash_v2_5
# Sensibilidad del barge-in (high|medium|low). Medium evita falsos cortes por ruido.
# VOICE_INTERRUPT_SENSITIVITY=medium

# ── Rate limiting / cache compartido ──────────────────────
# Opcional: si se setea, rate-limit usa Redis (multi-worker safe).
# Sin Redis funciona in-memory (1 worker).
# REDIS_URL=redis://...

# ── Rate limiting global ─────────────────────────────────
# Maximo de requests/min al webhook (todas las fuentes combinadas).
# Default: 200. Ajustar segun volumen esperado.
# RATE_LIMIT_GLOBAL_POR_MINUTO=200
